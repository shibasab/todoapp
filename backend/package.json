{
  "name": "@todoapp/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run prisma:generate",
    "dev": "bun --watch src/server.ts",
    "prestart": "npm run prisma:generate",
    "start": "bun src/server.ts",
    "prelint": "npm run prisma:generate",
    "lint": "oxlint --type-aware -c ../configs/oxlint/node.json src",
    "lint:check": "npm run lint",
    "lint:fix": "oxlint --fix --type-aware -c ../configs/oxlint/node.json src",
    "format": "oxfmt --config ../configs/oxfmt/base.json src tests vitest.config.ts tsconfig.json package.json",
    "format:check": "oxfmt --check --config ../configs/oxfmt/base.json src tests vitest.config.ts tsconfig.json package.json",
    "pretypecheck": "npm run prisma:generate",
    "typecheck": "tsgo",
    "pretest": "npm run prisma:generate",
    "test": "vitest run",
    "pretest:coverage": "npm run prisma:generate",
    "test:coverage": "vitest run --coverage",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@todoapp/shared": "file:../shared",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.14",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.13",
    "prisma": "^7.8.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
